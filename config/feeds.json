{
  "google_news_per_client": {
    "enabled": true,
    "template": "https://news.google.com/rss/search?q=%22{client}%22&hl=en-GB&gl=GB&ceid=GB:en",
    "comment": "{client} is URL-encoded canonical client name. Quoted for exact-phrase match."
  },
  "static_feeds": [
    {"name": "BBC Business",       "url": "https://feeds.bbci.co.uk/news/business/rss.xml",       "tags": ["national"]},
    {"name": "Guardian Business",  "url": "https://www.theguardian.com/uk/business/rss",          "tags": ["national"]},
    {"name": "Sky News Business",  "url": "https://feeds.skynews.com/feeds/rss/business.xml",     "tags": ["national"]},
    {"name": "FT Companies",       "url": "https://www.ft.com/companies?format=rss",              "tags": ["national", "paywall"]},
    {"name": "Reuters UK",         "url": "https://www.reutersagency.com/feed/?best-regions=united-kingdom&post_type=best", "tags": ["national"]},
    {"name": "Utility Week",       "url": "https://utilityweek.co.uk/feed/",                      "tags": ["trade", "utilities"]},
    {"name": "Current News",       "url": "https://www.current-news.co.uk/feed",                  "tags": ["trade", "energy"]},
    {"name": "Energy Live News",   "url": "https://www.energylivenews.com/feed/",                 "tags": ["trade", "energy"]},
    {"name": "Net Zero Investor",  "url": "https://www.netzeroinvestor.net/news.rss",             "tags": ["trade", "energy"]},
    {"name": "New Civil Engineer", "url": "https://www.newcivilengineer.com/feed/",               "tags": ["trade", "infrastructure"]},
    {"name": "Ofgem News",         "url": "https://www.ofgem.gov.uk/news/rss.xml",                "tags": ["primary", "regulator"]},
    {"name": "Ofwat News",         "url": "https://www.ofwat.gov.uk/feed/",                       "tags": ["primary", "regulator"]},
    {"name": "Gov.uk DESNZ",       "url": "https://www.gov.uk/government/organisations/department-for-energy-security-and-net-zero.atom", "tags": ["primary", "policy"]},
    {"name": "Gov.uk Defra",       "url": "https://www.gov.uk/government/organisations/department-for-environment-food-rural-affairs.atom", "tags": ["primary", "policy"]}
  ],
  "fetch": {
    "timeout_seconds": 15,
    "delay_between_requests_seconds": 1.5,
    "max_retries_per_feed": 2
  }
}
